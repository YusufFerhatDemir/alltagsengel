# ═══════════════════════════════════════════════════════════
# AlltagsEngel.care — Environment Variables Template
# ═══════════════════════════════════════════════════════════
# Kopiere diese Datei zu `.env.local` und fülle echte Werte ein.
# .env.local wird NICHT committed (siehe .gitignore).

# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Sentry (Error-Tracking + Performance) ────────────────
# DSN: findest du in Sentry → Settings → Projects → Client Keys
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# Build-Time (Source-Map-Upload): Sentry → User Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_YOUR_AUTH_TOKEN
SENTRY_ORG=alltagsengel
SENTRY_PROJECT=alltagsengel-web

# ─── Analytics & Marketing ────────────────────────────────
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id
NEXT_PUBLIC_TIKTOK_PIXEL_ID=your-tiktok-pixel-id

# ─── AI / LLM ─────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=...

# ─── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Push Notifications (Web Push VAPID) ──────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:info@alltagsengel.care

# ─── Geo / Location ───────────────────────────────────────
# (IP-API ist keyless, aber für höhere Limits Token nutzen)

# ─── Vercel (automatisch gesetzt in Production) ───────────
# VERCEL_GIT_COMMIT_SHA=auto-set-by-vercel
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=auto-set-by-vercel
