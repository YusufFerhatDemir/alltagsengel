{
  "expo": {
    "name": "AlltagsEngel",
    "slug": "alltagsengel-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "scheme": "alltagsengel",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1A1612"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alltagsengel.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1612"
      },
      "package": "com.alltagsengel.app"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-font"]
  }
}
